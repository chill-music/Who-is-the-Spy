{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Room Contract",
  "type": "object",
  "properties": {
    "gameType": {
      "type": "string",
      "enum": ["spy", "defuse_master"]
    },
    "status": {
      "type": "string",
      "enum": ["lobby", "playing", "results"]
    },
    "players": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "active": { "type": "boolean" },
          "ready": { "type": "boolean" }
        }
      }
    },
    "gameState": {
      "type": "object",
      "description": "Game-specific payload"
    }
  },
  "required": ["gameType", "status", "players"]
}

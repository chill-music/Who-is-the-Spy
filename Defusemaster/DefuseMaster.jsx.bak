import { useState, useEffect, useCallback, useRef } from "react";

/* ═══════════════════════════════ CONSTANTS ══════════════════════════════════ */
const CARD_DEFS = {
  bomb:     { label:"Bomb",     emoji:"💣", color:"#FF3B30", bg:"linear-gradient(135deg,#FF3B30,#C0392B)", terminal:false, desc:"تُفجّرك إن لم يكن معك Disable!" },
  disable:  { label:"Disable",  emoji:"🔑", color:"#30D158", bg:"linear-gradient(135deg,#30D158,#27AE60)", terminal:true,  desc:"فكّك القنبلة وضعها في أي مكان" },
  xray:     { label:"X-Ray",    emoji:"🔮", color:"#BF5AF2", bg:"linear-gradient(135deg,#BF5AF2,#8E44AD)", terminal:false, desc:"شاهد أعلى 3 كروت سراً ثم العب مجدداً" },
  prophecy: { label:"Prophecy", emoji:"💡", color:"#FFD60A", bg:"linear-gradient(135deg,#FFD60A,#F39C12)", terminal:false, desc:"اعرف الموضع الدقيق للقنبلة ثم العب مجدداً" },
  shuffle:  { label:"Shuffle",  emoji:"🔀", color:"#34C759", bg:"linear-gradient(135deg,#34C759,#2ECC71)", terminal:true,  desc:"اخلط جميع كروت الأرض عشوائياً" },
  bottom:   { label:"Bottom",   emoji:"⬇️", color:"#F0A500", bg:"linear-gradient(135deg,#FFD60A,#E67E22)", terminal:true,  desc:"اسحب الكرت الأخير من الأسفل" },
  demand:   { label:"Demand",   emoji:"🫴", color:"#0A84FF", bg:"linear-gradient(135deg,#0A84FF,#2980B9)", terminal:false, desc:"اطلب كرتاً من أي خصم ثم العب مجدداً" },
  exchange: { label:"Exchange", emoji:"🔄", color:"#FF375F", bg:"linear-gradient(135deg,#FF375F,#C0392B)", terminal:false, desc:"بادل يدك كاملة مع لاعب آخر ثم العب" },
  skip:     { label:"Skip",     emoji:"⏭️", color:"#64D2FF", bg:"linear-gradient(135deg,#64D2FF,#0A84FF)", terminal:true,  desc:"تخطَّ دورك · يُزيل عنك Trap" },
  reverse:  { label:"Reverse",  emoji:"🔁", color:"#9B59B6", bg:"linear-gradient(135deg,#BF5AF2,#9B59B6)", terminal:true,  desc:"اعكس اتجاه الأدوار · يُزيل عنك Trap" },
  trap:     { label:"Trap",     emoji:"🍳", color:"#FF9F0A", bg:"linear-gradient(135deg,#FF9F0A,#E67E22)", terminal:true,  desc:"أجبر لاعباً على سحب كروت زائدة! يتراكم" },
};

const GOLD_REWARDS = { 5:[1.5,0.5,0,-0.5,-1], 4:[1.2,0.3,-0.5,-1], 3:[1,0,-1], 2:[1,-1] };
const BOT_NAMES   = ["Mona 🌸","Kareem ⚡","Sara 🌙","Ahmed 🔥","Layla ✨"];
const BOT_AVATARS = ["👩‍🦰","👨‍🦱","👩","👨‍🦲","👩‍🦳"];
const SWAP_COST   = 5;

/* ══════════════════════════════════ UTILS ═══════════════════════════════════ */
const uuid = () => Math.random().toString(36).slice(2, 10);

function shuffleArr(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function buildDeck(playerCount) {
  const cards = [];
  const add = (t, n) => { for (let i = 0; i < n; i++) cards.push({ id: uuid(), type: t }); };
  add("disable",  6);  //
  add("xray",     5);  //
  add("prophecy", 5);  //
  add("shuffle",  5);  //
  add("bottom",   5);  //  total = 53 non-bomb cards
  add("demand",   6);  //
  add("exchange", 5);  //
  add("skip",     6);  //
  add("reverse",  4);  //
  add("trap",     6);  //
  const bombs = Array.from({ length: playerCount - 1 }, () => ({ id: uuid(), type: "bomb" }));
  return { dealDeck: shuffleArr(cards), bombs };
}

function dealHands(dealDeck, players) {
  const deck = [...dealDeck];
  const hands = {};
  players.forEach(p => {
    const di = deck.findIndex(c => c.type === "disable");
    const hand = [deck.splice(di !== -1 ? di : 0, 1)[0]];
    for (let i = 0; i < 4 && deck.length; i++) hand.push(deck.shift());
    hands[p.id] = hand;
  });
  return { hands, remaining: deck };
}

/* Symmetric ellipse positions for lobby — "you" always at bottom */
function getLobbyPositions(playerCount) {
  const cx = 140, cy = 120, rx = 108, ry = 90;
  const r2d = d => d * Math.PI / 180;
  const pt  = a => ({
    left: `${((cx + rx * Math.cos(r2d(a))) / 280 * 100).toFixed(1)}%`,
    top:  `${((cy - ry * Math.sin(r2d(a))) / 260 * 100).toFixed(1)}%`,
  });
  const cfgs = {
    2: [-90, 90],
    3: [-90, 150, 30],
    4: [-90, 150, 90, 30],
    5: [-90, 150, 110, 70, 30],
  };
  return (cfgs[playerCount] || cfgs[2]).map(a => pt(a));
}

/* ════════════════════════════════ CARD UI ═══════════════════════════════════ */
function CardUI({ card, size = "md", onClick, selected, disabled, faceDown, trapStack = 0 }) {
  const def = CARD_DEFS[card?.type] || {};
  const sz  = { sm:{w:52,h:72,font:18,lbl:9}, md:{w:72,h:100,font:26,lbl:11}, lg:{w:110,h:154,font:40,lbl:14} }[size];
  return (
    <div onClick={!disabled ? onClick : undefined} style={{
      width: sz.w, height: sz.h, borderRadius: 14,
      background: faceDown ? "linear-gradient(135deg,#2C1654,#1A0A3C)" : def.bg,
      border: selected ? "3px solid #FFD60A"
            : faceDown ? "2px solid #4A2080" : "2px solid rgba(255,255,255,0.22)",
      display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center",
      cursor: disabled ? "default" : "pointer",
      boxShadow: selected ? "0 0 22px #FFD60A99,0 6px 20px rgba(0,0,0,0.5)"
                          : "0 6px 20px rgba(0,0,0,0.4)",
      transform: selected ? "translateY(-10px) scale(1.07)" : "scale(1)",
      transition: "all 0.2s ease",
      flexShrink: 0, position: "relative", overflow: "hidden",
      opacity: disabled ? 0.45 : 1,
    }}>
      {!faceDown && <>
        <div style={{ position:"absolute",inset:0,background:"rgba(255,255,255,0.06)" }} />
        <div style={{ fontSize: sz.font, lineHeight: 1 }}>{def.emoji}</div>
        <div style={{
          fontSize: sz.lbl, fontWeight: 800, color: "white",
          textShadow: "0 1px 4px rgba(0,0,0,0.5)", marginTop: 4,
          fontFamily: "'Baloo 2',cursive",
        }}>{def.label}</div>
        {card?.type === "trap" && trapStack > 1 && (
          <div style={{
            position:"absolute",top:4,right:4,
            background:"#FF3B30",borderRadius:8,padding:"1px 6px",
            fontSize:9,fontWeight:900,color:"white",
          }}>×{trapStack}</div>
        )}
      </>}
      {faceDown && <div style={{ fontSize: sz.font * 0.7, opacity: 0.25 }}>🂠</div>}
    </div>
  );
}

/* ══════════════════════════════════ MODAL ═══════════════════════════════════ */
function Modal({ children, onClose, danger }) {
  return (
    <div style={{
      position:"fixed",inset:0,zIndex:1000,
      background: danger ? "rgba(255,59,48,0.25)" : "rgba(0,0,0,0.72)",
      backdropFilter:"blur(10px)",
      display:"flex",alignItems:"center",justifyContent:"center",padding:20,
    }}>
      <div style={{
        background:"linear-gradient(160deg,#2C1654,#1A0A3C)",
        border: danger ? "2px solid #FF3B30" : "2px solid rgba(255,255,255,0.15)",
        borderRadius:24,padding:28,maxWidth:340,width:"100%",
        boxShadow: danger ? "0 0 60px rgba(255,59,48,0.5)" : "0 20px 60px rgba(0,0,0,0.8)",
        animation:"modalIn 0.3s ease",position:"relative",
      }}>
        {children}
        {onClose && (
          <button onClick={onClose} style={{
            position:"absolute",top:12,right:12,
            background:"rgba(255,255,255,0.1)",border:"none",borderRadius:"50%",
            width:32,height:32,color:"white",cursor:"pointer",fontSize:16,
          }}>✕</button>
        )}
      </div>
    </div>
  );
}

/* ═══════════════════════════════ LOBBY SCREEN ═══════════════════════════════ */
function LobbyScreen({ onStart }) {
  const [botCount, setBotCount] = useState(2);
  const [stake,    setStake]    = useState(100);
  const playerCount = botCount + 1;
  const positions   = getLobbyPositions(playerCount);
  const players = [
    { id:"you", name:"أنت", avatar:"😎", isYou:true },
    ...Array.from({ length:botCount }, (_,i) => ({
      id:`bot${i}`, name:BOT_NAMES[i], avatar:BOT_AVATARS[i], isYou:false,
    })),
  ];

  return (
    <div style={{
      minHeight:"100vh",fontFamily:"'Baloo 2',cursive",
      background:"linear-gradient(160deg,#5B2D8E 0%,#3A1A6E 50%,#1A0A3C 100%)",
      display:"flex",flexDirection:"column",alignItems:"center",
      padding:"20px 16px",position:"relative",overflow:"hidden",
    }}>
      <div style={{
        position:"absolute",inset:0,opacity:0.05,
        backgroundImage:"radial-gradient(circle,white 1px,transparent 1px)",
        backgroundSize:"30px 30px",
      }}/>
      {/* Header */}
      <div style={{ zIndex:10,textAlign:"center",marginBottom:8 }}>
        <div style={{ fontSize:36 }}>💣</div>
        <h1 style={{
          fontSize:28,fontWeight:900,color:"white",margin:0,
          textShadow:"0 0 30px rgba(255,214,10,0.5)",letterSpacing:1,
        }}>Defuse Master</h1>
        <p style={{ color:"rgba(255,255,255,0.5)",fontSize:13,margin:0 }}>Junior Room · Gold</p>
      </div>

      {/* VS Arena */}
      <div style={{ position:"relative",width:280,height:260,margin:"10px auto",zIndex:10 }}>
        {/* Dashed ellipse guide */}
        <svg style={{ position:"absolute",inset:0,width:"100%",height:"100%",overflow:"visible",pointerEvents:"none" }}>
          <ellipse cx="140" cy="120" rx="108" ry="90"
            fill="none" stroke="rgba(255,255,255,0.08)" strokeWidth="1.5" strokeDasharray="6 10"/>
        </svg>
        {/* Center VS badge */}
        <div style={{
          position:"absolute",top:"50%",left:"50%",transform:"translate(-50%,-50%)",
          width:68,height:68,borderRadius:"50%",
          background:"rgba(255,255,255,0.08)",border:"2px solid rgba(255,255,255,0.18)",
          display:"flex",alignItems:"center",justifyContent:"center",
          boxShadow:"0 0 30px rgba(255,214,10,0.2)",
        }}>
          <span style={{ color:"white",fontWeight:900,fontSize:20,letterSpacing:2 }}>VS</span>
        </div>
        {/* Filled player slots */}
        {positions.slice(0, playerCount).map((pos, i) => {
          const p = players[i];
          return (
            <div key={p.id} style={{ position:"absolute",left:pos.left,top:pos.top,transform:"translate(-50%,-50%)" }}>
              <div style={{
                display:"flex",flexDirection:"column",alignItems:"center",gap:5,
                animation:`circleIn 0.45s ease ${i*0.12}s both`,
              }}>
                <div style={{
                  width:56,height:56,borderRadius:"50%",
                  background: p.isYou ? "linear-gradient(135deg,#FFD60A,#FF9F0A)" : "rgba(255,255,255,0.12)",
                  border: p.isYou ? "3px solid #FFD60A" : "2px solid rgba(255,255,255,0.22)",
                  display:"flex",alignItems:"center",justifyContent:"center",fontSize:26,
                  boxShadow: p.isYou ? "0 0 22px rgba(255,214,10,0.45)" : "0 4px 12px rgba(0,0,0,0.3)",
                  position:"relative",
                }}>
                  {p.avatar}
                  <div style={{
                    position:"absolute",bottom:-2,right:-2,
                    width:16,height:16,borderRadius:"50%",
                    background:"#30D158",border:"2px solid #1A0A3C",
                  }}/>
                </div>
                <div style={{
                  fontSize:11,color:"white",fontWeight:700,
                  background:"rgba(0,0,0,0.5)",padding:"2px 9px",borderRadius:10,

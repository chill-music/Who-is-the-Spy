}

/* ══════════════════════════════ SWAP PHASE ══════════════════════════════════ */
function SwapPhase({ hands, deck, onComplete, stake }) {
  const [countdown, setCountdown] = useState(5);
  const [yourHand,  setYourHand]  = useState([...hands["you"]]);
  const [deckState, setDeckState] = useState([...deck]);
  const [gold,      setGold]      = useState(stake);
  const [swaps,     setSwaps]     = useState(0);
  const doneRef = useRef(false);

  const finish = useCallback((hand, d) => {
    if (doneRef.current) return;
    doneRef.current = true;
    onComplete({ ...hands, you: hand }, d);
  }, [hands, onComplete]);

  useEffect(() => {
    if (countdown <= 0) { finish(yourHand, deckState); return; }
    const t = setTimeout(() => setCountdown(c => c - 1), 1000);
    return () => clearTimeout(t);
  }, [countdown, yourHand, deckState, finish]);

  const swapCard = (idx) => {
    if (gold < SWAP_COST || !deckState.length) return;
    const d = [...deckState];
    const newCard = d.shift();
    const newHand = [...yourHand];
    d.push(newHand[idx]);
    newHand[idx] = newCard;
    setYourHand(newHand);
    setDeckState(shuffleArr(d));
    setGold(g => g - SWAP_COST);
    setSwaps(s => s + 1);
  };

  const pct = (countdown / 5) * 100;
  const r   = 34;
  const circ = 2 * Math.PI * r;

  return (
    <div style={{
      minHeight:"100vh",fontFamily:"'Baloo 2',cursive",
      background:"linear-gradient(160deg,#5B2D8E 0%,#3A1A6E 50%,#1A0A3C 100%)",
      display:"flex",flexDirection:"column",alignItems:"center",
      padding:"30px 20px",
    }}>
      {/* Countdown ring */}
      <div style={{ position:"relative",width:80,height:80,marginBottom:16 }}>
        <svg width="80" height="80" style={{ transform:"rotate(-90deg)" }}>
          <circle cx="40" cy="40" r={r} fill="none" stroke="rgba(255,255,255,0.1)" strokeWidth="6"/>
          <circle cx="40" cy="40" r={r} fill="none"
            stroke={countdown <= 2 ? "#FF3B30" : "#FFD60A"}
            strokeWidth="6" strokeDasharray={circ}
            strokeDashoffset={circ * (1 - pct/100)}
            strokeLinecap="round"
            style={{ transition:"stroke-dashoffset 0.9s linear,stroke 0.3s" }}
          />
        </svg>
        <div style={{
          position:"absolute",inset:0,display:"flex",alignItems:"center",justifyContent:"center",
        }}>
          <span style={{
            fontSize:28,fontWeight:900,
            color: countdown <= 2 ? "#FF3B30" : "#FFD60A",
          }}>{countdown}</span>
        </div>
      </div>

      <h2 style={{ color:"white",fontWeight:900,fontSize:20,margin:"0 0 4px",textAlign:"center" }}>
        استبدال الكروت
      </h2>
      <p style={{ color:"rgba(255,255,255,0.5)",fontSize:13,margin:"0 0 14px",textAlign:"center" }}>
        اضغط على أي كرت لاستبداله مقابل {SWAP_COST} Gold
      </p>

      <div style={{
        background:"rgba(255,214,10,0.13)",border:"1px solid rgba(255,214,10,0.3)",
        borderRadius:12,padding:"6px 18px",marginBottom:20,
        color:"#FFD60A",fontWeight:800,fontSize:14,
      }}>💰 {gold} Gold متاح</div>

      {/* Hand cards */}
      <div style={{ display:"flex",gap:10,flexWrap:"wrap",justifyContent:"center",marginBottom:24 }}>
        {yourHand.map((card, i) => (
          <div key={card.id} style={{ display:"flex",flexDirection:"column",alignItems:"center",gap:6 }}>
            <CardUI card={card} size="md" onClick={() => swapCard(i)} disabled={gold < SWAP_COST}/>
            <button onClick={() => swapCard(i)} disabled={gold < SWAP_COST} style={{
              padding:"4px 12px",borderRadius:20,
              background: gold >= SWAP_COST ? "rgba(255,214,10,0.18)" : "rgba(255,255,255,0.05)",
              border:"1px solid rgba(255,214,10,0.3)",
              color: gold >= SWAP_COST ? "#FFD60A" : "rgba(255,255,255,0.25)",
              fontSize:11,fontWeight:700,cursor: gold >= SWAP_COST ? "pointer" : "default",
              fontFamily:"'Baloo 2',cursive",
            }}>استبدل ({SWAP_COST}💰)</button>
          </div>
        ))}
      </div>

      <button onClick={() => finish(yourHand, deckState)} style={{
        padding:"14px 44px",borderRadius:50,
        background:"linear-gradient(135deg,#30D158,#27AE60)",
        border:"none",color:"white",fontSize:16,fontWeight:900,cursor:"pointer",
        fontFamily:"'Baloo 2',cursive",boxShadow:"0 8px 24px rgba(48,209,88,0.4)",
      }}>✅ جاهز!</button>

      {swaps > 0 && (
        <p style={{ color:"rgba(255,255,255,0.35)",fontSize:12,marginTop:12 }}>
          استبدلت {swaps} كرت · خُصم {swaps * SWAP_COST} Gold
        </p>
      )}
    </div>
  );
}

/* ════════════════════════════ BOMB PLACEMENT ════════════════════════════════ */
function BombPlacement({ deckSize, onConfirm }) {
  const [pos, setPos] = useState(0);
  const max = deckSize;
  return (
    <div style={{ marginBottom:10 }}>
      <p style={{ color:"rgba(255,255,255,0.6)",fontSize:12,margin:"0 0 8px" }}>
        ضع القنبلة في الموضع:{" "}
        <strong style={{ color:"#FFD60A" }}>
          {pos === 0 ? "الأعلى" : pos >= max ? "الأسفل" : `#${pos+1}`}
        </strong>
      </p>
      <input type="range" min={0} max={max} value={pos}
        onChange={e => setPos(Number(e.target.value))}
        style={{ width:"100%",accentColor:"#FFD60A",marginBottom:12 }}
      />
      <button onClick={() => onConfirm(pos)} style={{
        width:"100%",padding:"13px 0",borderRadius:50,
        background:"linear-gradient(135deg,#30D158,#27AE60)",
        border:"none",color:"white",fontWeight:900,fontSize:15,cursor:"pointer",
        fontFamily:"'Baloo 2',cursive",boxShadow:"0 4px 16px rgba(48,209,88,0.4)",
      }}>🔑 استخدم Disable وضع القنبلة!</button>
    </div>
  );
}

/* ════════════════════════════════ GAME SCREEN ═══════════════════════════════ */
function GameScreen({ config, onEnd }) {
  const { botCount, stake, playerCount } = config;

  const makePlayers = () => {
    const ps = [{ id:"you",name:"أنت",avatar:"😎",isBot:false }];
    for (let i = 0; i < botCount; i++)
      ps.push({ id:`bot${i}`,name:BOT_NAMES[i],avatar:BOT_AVATARS[i],isBot:true });
    return ps;
  };

  /* ── Setup ────────────────────────────────────────────────────────────── */
  const setupGame = () => {
    const players = makePlayers().map(p => ({
      ...p, status:"alive", rank:null, trapMultiplier:0,
    }));
    const { dealDeck, bombs } = buildDeck(playerCount);
    const { hands, remaining } = dealHands(dealDeck, players);
    const withBombs  = shuffleArr([...remaining, ...bombs]);
    const turnOrder  = shuffleArr(players.map(p => p.id));
    return { players, hands, deck:withBombs, turnOrder, currentTurn:turnOrder[0], direction:1 };
  };

  const [phase,          setPhase]          = useState("swap"); // "swap" | "play"
  const [baseState,      setBaseState]      = useState(setupGame);
  const [gs,             setGs]             = useState(null);
  const [selectedCard,   setSelectedCard]   = useState(null);
  const [selectingFor,   setSelectingFor]   = useState(null); // card type needing target
  const [modal,          setModal]          = useState(null);
  const [lastAction,     setLastAction]     = useState(null);
  const [log,            setLog]            = useState([]);
  const botTimerRef = useRef(null);

  const addLog = msg => setLog(l => [msg, ...l].slice(0, 8));

  const alivePs  = g => g.players.filter(p => p.status === "alive");
  const curP     = g => g.players.find(p => p.id === g.currentTurn);
  const isYourTurn = gs ? gs.currentTurn === "you" : false;
  const yourTrap   = gs ? (gs.players.find(p => p.id === "you")?.trapMultiplier || 0) : 0;

  /* ── Advance Turn ─────────────────────────────────────────────────────── */
  const advanceTurn = useCallback((g) => {
    const alive = alivePs(g).map(p => p.id);
    if (alive.length <= 1) { endGame(g, alive[0]); return g; }
    const order = g.turnOrder.filter(id => alive.includes(id));
    const idx   = order.indexOf(g.currentTurn);
    const dir   = g.direction || 1;
    const next  = order[((idx + dir) % order.length + order.length) % order.length];
    return { ...g, currentTurn: next };
  }, []);

  /* ── End Game ─────────────────────────────────────────────────────────── */
  const endGame = useCallback((g, winnerId) => {
    const allPs  = g.players.map((p, i) => ({
      ...p, rank: p.id === winnerId ? 1 : (p.rank || g.players.length - i),
    }));
    const rewards = GOLD_REWARDS[playerCount] || GOLD_REWARDS[2];
    const sorted  = [...allPs].sort((a, b) => a.rank - b.rank);
    const goldMap = {};
    sorted.forEach((p, i) => { goldMap[p.id] = (rewards[i] || 0) * stake; });
    setTimeout(() => onEnd({ players: allPs, goldMap, winnerId, stake }), 500);
  }, [playerCount, stake, onEnd]);

  /* ── Eliminate Player ─────────────────────────────────────────────────── */
  const eliminatePlayer = useCallback((g, uid, bomb) => {
    const alive    = alivePs(g).filter(p => p.id !== uid);
    const rank     = alive.length + 1;
    const newDeck  = shuffleArr([...g.deck, bomb]);
    const newPs    = g.players.map(p =>
      p.id === uid ? { ...p, status:"eliminated", rank } : p
    );
    addLog(`💥 ${g.players.find(p => p.id === uid)?.name} خرج من اللعبة!`);
    let ng = { ...g, players: newPs, deck: newDeck };
    if (alive.length <= 1) { endGame(ng, alive[0]?.id); return ng; }
    return advanceTurn({ ...ng, currentTurn: uid });
  }, [advanceTurn, endGame]);

  /* ── Swap Phase Complete ──────────────────────────────────────────────── */
  const handleSwapComplete = (newHands, newDeck) => {
    const startGs = { ...baseState, hands: newHands, deck: newDeck };
    setGs(startGs);
    setPhase("play");
  };

  /* ── Draw Card ────────────────────────────────────────────────────────── */
  const drawCard = useCallback((fromBottom = false) => {
    if (!isYourTurn || modal) return;
    setGs(prev => {
      if (!prev.deck.length) return advanceTurn(prev);
      const deck = [...prev.deck];
      const card = fromBottom ? deck.pop() : deck.shift();
      setLastAction({ type:"draw", card });
      if (card.type === "bomb") {
        const hasDisable = (prev.hands["you"] || []).some(c => c.type === "disable");
        setModal({ type:"bomb", card, hasDisable });
        return { ...prev, deck };
      }
      addLog(`🃏 سحبت ${CARD_DEFS[card.type]?.label}`);
      const hand = [...(prev.hands["you"] || []), card];
      return advanceTurn({ ...prev, deck, hands: { ...prev.hands, you: hand } });
    });
    setSelectedCard(null);
    setSelectingFor(null);
  }, [isYourTurn, modal, advanceTurn]);

  /* ── Play Card ────────────────────────────────────────────────────────── */
  const playCard = useCallback((cardId, targetId) => {
    if (!isYourTurn || modal) return;
    setGs(prev => {
      const hand    = prev.hands["you"] || [];
      const card    = hand.find(c => c.id === cardId);
      if (!card) return prev;
      const newHand = hand.filter(c => c.id !== cardId);
      let ng = { ...prev, hands: { ...prev.hands, you: newHand } };
      setLastAction({ type:"play", card });
      addLog(`▶️ لعبت ${CARD_DEFS[card.type]?.label}`);

      switch (card.type) {

        case "xray": {
          const top3 = ng.deck.slice(0, 3);
          setModal({ type:"xray", cards: top3 });
          return ng; // player continues acting
        }

        case "prophecy": {
          const bombPos = ng.deck.findIndex(c => c.type === "bomb");
          setModal({ type:"prophecy", pos: bombPos });
          return ng; // player continues acting
        }

        case "shuffle": {
          addLog("🔀 تم خلط الكروت!");
          return advanceTurn({ ...ng, deck: shuffleArr(ng.deck) });
        }

        case "bottom": {
          if (!ng.deck.length) return advanceTurn(ng);
          const btm  = ng.deck[ng.deck.length - 1];
          const deck = ng.deck.slice(0, -1);
          if (btm.type === "bomb") {
            const hasDisable = newHand.some(c => c.type === "disable");
            setModal({ type:"bomb", card: btm, hasDisable });
            return { ...ng, deck };
          }
          addLog(`⬇️ سحبت من الأسفل: ${CARD_DEFS[btm.type]?.label}`);
          return advanceTurn({ ...ng, deck, hands: { ...ng.hands, you: [...newHand, btm] } });
        }

        case "demand": {
          if (!targetId) { setSelectingFor("demand"); return { ...prev }; }
          const tHand = ng.hands[targetId] || [];
          if (!tHand.length) { addLog("🫴 لا توجد كروت لديهم!"); return ng; }
          const gIdx   = Math.floor(Math.random() * tHand.length);
          const given  = tHand[gIdx];
          const tName  = ng.players.find(p => p.id === targetId)?.name || targetId;
          addLog(`🫴 ${tName} أعطاك ${CARD_DEFS[given.type]?.label}!`);
          return {
            ...ng,
            hands: {
              ...ng.hands,
              [targetId]: tHand.filter((_, i) => i !== gIdx),
              you: [...newHand, given],
            },
          }; // player continues acting
        }

        case "exchange": {
          if (!targetId) { setSelectingFor("exchange"); return { ...prev }; }
          const tHand = ng.hands[targetId] || [];
          const tName = ng.players.find(p => p.id === targetId)?.name || targetId;
          addLog(`🔄 بدّلت يدك مع ${tName}!`);
          return {
            ...ng,
            hands: { ...ng.hands, you: tHand, [targetId]: newHand },
          }; // player continues acting
        }

        case "skip": {
          addLog("⏭️ تخطيت دورك");
          const ps = ng.players.map(p => p.id === "you" ? { ...p, trapMultiplier:0 } : p);
          return advanceTurn({ ...ng, players: ps });
        }

        case "reverse": {
          const newDir = -(ng.direction || 1);
          addLog("🔁 تم عكس اتجاه الأدوار!");
          const ps = ng.players.map(p => p.id === "you" ? { ...p, trapMultiplier:0 } : p);
          return advanceTurn({ ...ng, direction: newDir, players: ps });
        }

        case "trap": {
          if (!targetId) { setSelectingFor("trap"); return { ...prev }; }
          const myTrap   = ng.players.find(p => p.id === "you")?.trapMultiplier || 0;
          const newStack = myTrap + 1;
          const tgt      = ng.players.find(p => p.id === targetId);
          addLog(`🍳 Trap ×${newStack} على ${tgt?.name}!`);
          const ps = ng.players.map(p => {
            if (p.id === targetId) return { ...p, trapMultiplier: (p.trapMultiplier || 0) + newStack };
            if (p.id === "you")    return { ...p, trapMultiplier: 0 };
            return p;
          });
          return advanceTurn({ ...ng, players: ps });
        }

        default:
          return advanceTurn(ng);
      }
    });
    setSelectedCard(null);
    setSelectingFor(null);
  }, [isYourTurn, modal, advanceTurn]);

  /* ── Bomb Response ────────────────────────────────────────────────────── */
  const handleBombResponse = (useDisable, placement) => {
    setModal(null);
    setGs(prev => {
      const bomb = modal.card;
      if (useDisable) {
        const hand  = prev.hands["you"] || [];
        const dIdx  = hand.findIndex(c => c.type === "disable");
        const newH  = hand.filter((_, i) => i !== dIdx);
        const pos   = placement !== undefined ? placement : Math.floor(Math.random() * (prev.deck.length + 1));
        const deck  = [...prev.deck];
        deck.splice(pos, 0, bomb);
        addLog("🔑 استخدمت Disable! وضعت القنبلة في مكان سري");
        return advanceTurn({ ...prev, deck, hands: { ...prev.hands, you: newH } });
      }
      return eliminatePlayer(prev, "you", bomb);
    });
  };

  /* ── Bot Turn ─────────────────────────────────────────────────────────── */
  useEffect(() => {
    if (!gs || modal || isYourTurn || phase !== "play") return;
    const botId = gs.currentTurn;
    const bot   = gs.players.find(p => p.id === botId);
    if (!bot || bot.status !== "alive" || !bot.isBot) return;

    const delay = 900 + Math.random() * 700;
    botTimerRef.current = setTimeout(() => {
      setGs(prev => {
        if (prev.currentTurn !== botId) return prev;
        const hand  = prev.hands[botId] || [];
        const trap  = prev.players.find(p => p.id === botId)?.trapMultiplier || 0;

        /* ─ Forced draws from trap ─ */
        if (trap > 0) {
          let ng = { ...prev };
          for (let i = 0; i < trap && ng.deck.length; i++) {
            const deck = [...ng.deck];
            const card = deck.shift();
            if (card.type === "bomb") {
              const hasD = (ng.hands[botId] || []).some(c => c.type === "disable");
              if (hasD) {
                const h   = (ng.hands[botId] || []).filter(c => c.type !== "disable");
                const pos = Math.floor(Math.random() * (deck.length + 1));
                deck.splice(pos, 0, card);
                addLog(`🔑 ${bot.name} استخدم Disable!`);
                ng = { ...ng, deck, hands: { ...ng.hands, [botId]: h } };
              } else {
                addLog(`💥 ${bot.name} فجّر!`);
                const newPs = ng.players.map(p =>
                  p.id === botId ? { ...p, status:"eliminated", rank: alivePs(ng).filter(x => x.id !== botId).length + 1 } : p
                );
                ng = { ...ng, deck, players: newPs };
                const alive = alivePs(ng);
                if (alive.length <= 1) { endGame(ng, alive[0]?.id); return ng; }
                return advanceTurn({ ...ng, players: newPs.map(p => p.id === botId ? p : { ...p, trapMultiplier:0 }) });
              }
              break;
            } else {
              ng = { ...ng, deck, hands: { ...ng.hands, [botId]: [...(ng.hands[botId]||[]), card] } };
            }
          }
          const resetPs = ng.players.map(p => p.id === botId ? { ...p, trapMultiplier:0 } : p);
          return advanceTurn({ ...ng, players: resetPs });
        }

        /* ─ Card plays ─ */
        const trapC    = hand.find(c => c.type === "trap");
        const shuffleC = hand.find(c => c.type === "shuffle");
        const skipC    = hand.find(c => c.type === "skip");
        const revC     = hand.find(c => c.type === "reverse");

        if (shuffleC && Math.random() < 0.25) {
          addLog(`🔀 ${bot.name} خلط الكروت`);
          return advanceTurn({ ...prev, deck: shuffleArr(prev.deck), hands: { ...prev.hands, [botId]: hand.filter(c => c.id !== shuffleC.id) } });
        }
        if (trapC && Math.random() < 0.22) {
          const targets = alivePs(prev).filter(p => p.id !== botId);
          if (targets.length) {
            const t     = targets[Math.floor(Math.random() * targets.length)];
            const stack = (t.trapMultiplier || 0) + 1;
            addLog(`🍳 ${bot.name} وضع Trap ×${stack} على ${t.name}!`);
            const ps = prev.players.map(p =>
              p.id === t.id ? { ...p, trapMultiplier: (p.trapMultiplier||0) + 1 } : p
            );
            return advanceTurn({ ...prev, players: ps, hands: { ...prev.hands, [botId]: hand.filter(c => c.id !== trapC.id) } });
          }
        }
        if (skipC && Math.random() < 0.12) {
          addLog(`⏭️ ${bot.name} تخطّى دوره`);
          return advanceTurn({ ...prev, hands: { ...prev.hands, [botId]: hand.filter(c => c.id !== skipC.id) } });
        }
        if (revC && Math.random() < 0.10) {
          addLog(`🔁 ${bot.name} عكس الاتجاه`);
          return advanceTurn({ ...prev, direction: -(prev.direction||1), hands: { ...prev.hands, [botId]: hand.filter(c => c.id !== revC.id) } });
        }

        /* ─ Draw ─ */
        if (!prev.deck.length) return advanceTurn(prev);
        const deck = [...prev.deck];
        const card = deck.shift();
        setLastAction({ type:"draw", card, botId });
        addLog(`🤖 ${bot.name} سحب كرت`);
        if (card.type === "bomb") {
          const hasD = hand.some(c => c.type === "disable");
          if (hasD) {
            const h   = hand.filter(c => c.type !== "disable");
            const pos = Math.floor(Math.random() * (deck.length + 1));
            deck.splice(pos, 0, card);
            addLog(`🔑 ${bot.name} استخدم Disable!`);
            return advanceTurn({ ...prev, deck, hands: { ...prev.hands, [botId]: h } });
          }
          addLog(`💥 ${bot.name} فجّر!`);
          return eliminatePlayer({ ...prev, deck }, botId, card);
        }
        return advanceTurn({ ...prev, deck, hands: { ...prev.hands, [botId]: [...hand, card] } });
      });
    }, delay);

    return () => clearTimeout(botTimerRef.current);
  }, [gs?.currentTurn, modal, isYourTurn, phase, advanceTurn, eliminatePlayer, endGame]);

  /* ─── Render swap phase ───────────────────────────────────────────────── */
  if (phase === "swap") {
    return (
      <SwapPhase
        hands={baseState.hands}
        deck={baseState.deck}
        onComplete={handleSwapComplete}
        stake={stake}
      />
    );
  }

  if (!gs) return null;

  /* ─── Derived values ──────────────────────────────────────────────────── */
  const yourHand    = gs.hands["you"] || [];
  const currentPl   = curP(gs);
  const bombCount   = gs.deck.filter(c => c.type === "bomb").length;
  const bombPct     = gs.deck.length > 0 ? Math.round(bombCount / gs.deck.length * 100) : 0;
  const direction   = gs.direction || 1;
  const R = 38, CIRC = 2 * Math.PI * R;

  /* Allowed cards when trapped */
  const isTrapped       = yourTrap > 0;
  const trapEscapeTypes = new Set(["skip","reverse","trap"]);
  const cardAllowed     = (c) => !isTrapped || trapEscapeTypes.has(c.type);

  return (
    <div style={{
      height:"100vh",fontFamily:"'Baloo 2',cursive",
      background:"linear-gradient(160deg,#5B2D8E 0%,#3A1A6E 50%,#1A0A3C 100%)",
      display:"flex",flexDirection:"column",overflow:"hidden",userSelect:"none",
    }}>

      {/* ── TOP BAR ─────────────────────────────────────────────────── */}
      <div style={{
        display:"flex",alignItems:"center",justifyContent:"space-between",
        padding:"10px 10px 6px",gap:4,flexShrink:0,
        background:"rgba(0,0,0,0.25)",
      }}>
        {gs.players.map(p => (
          <div key={p.id} style={{
            display:"flex",flexDirection:"column",alignItems:"center",
            opacity: p.status === "eliminated" ? 0.3 : 1,
            filter: p.status === "eliminated" ? "grayscale(1)" : "none",
            transition:"all 0.5s",flex:1,
          }}>
            <div style={{
              width:44,height:44,borderRadius:"50%",
              background: p.id === "you"
                ? "linear-gradient(135deg,#FFD60A,#FF9F0A)"
                : "rgba(255,255,255,0.1)",
              display:"flex",alignItems:"center",justifyContent:"center",fontSize:20,
              border: gs.currentTurn === p.id
                ? "3px solid #FFD60A"
                : "2px solid rgba(255,255,255,0.12)",
              boxShadow: gs.currentTurn === p.id ? "0 0 14px rgba(255,214,10,0.65)" : "none",
              animation: gs.currentTurn === p.id && p.status === "alive" ? "glow 1.5s infinite" : "none",
              position:"relative",
            }}>
              {p.avatar}
              {p.status === "eliminated" && (
                <div style={{
                  position:"absolute",inset:0,borderRadius:"50%",
                  background:"rgba(0,0,0,0.65)",display:"flex",alignItems:"center",justifyContent:"center",
                  fontSize:16,
                }}>💀</div>
              )}
              {p.trapMultiplier > 0 && (
                <div style={{
                  position:"absolute",top:-4,right:-4,
                  background:"#FF9F0A",borderRadius:8,padding:"1px 5px",
                  fontSize:9,fontWeight:900,color:"white",
                }}>×{p.trapMultiplier}</div>
              )}
            </div>
            <div style={{
              fontSize:9,color:"rgba(255,255,255,0.55)",marginTop:2,
              maxWidth:50,textAlign:"center",overflow:"hidden",
              textOverflow:"ellipsis",whiteSpace:"nowrap",
            }}>{p.name.split(" ")[0]}</div>
            <div style={{
              background:"#BF5AF2",borderRadius:7,padding:"1px 6px",
              fontSize:10,fontWeight:800,color:"white",marginTop:1,
            }}>{(gs.hands[p.id] || []).length}</div>
          </div>
        ))}
      </div>

      {/* ── ACTION LOG ─────────────────────────────────────────────── */}
      {log[0] && (
        <div style={{
          textAlign:"center",padding:"4px 12px",
          color:"rgba(255,255,255,0.65)",fontSize:11,
          background:"rgba(0,0,0,0.15)",flexShrink:0,
        }}>{log[0]}</div>
      )}

      {/* ── MIDDLE AREA ────────────────────────────────────────────── */}
      <div style={{
        flex:1,display:"flex",alignItems:"center",
        justifyContent:"space-around",padding:"0 16px",gap:12,
      }}>
        {/* Draw Pile + % gauge */}
        <div style={{ display:"flex",flexDirection:"column",alignItems:"center",gap:6 }}>
          {/* Bomb probability ring */}
          <div style={{ position:"relative",width:82,height:82 }}>
            <svg width="82" height="82" style={{ position:"absolute",top:0,left:0,transform:"rotate(-90deg)" }}>
              <circle cx="41" cy="41" r={R} fill="none" stroke="rgba(255,255,255,0.1)" strokeWidth="6"/>
              <circle cx="41" cy="41" r={R} fill="none"
                stroke={bombPct > 40 ? "#FF3B30" : bombPct > 20 ? "#FF9F0A" : "#FFD60A"}
                strokeWidth="6"
                strokeDasharray={CIRC}
                strokeDashoffset={CIRC * (1 - bombPct / 100)}
                strokeLinecap="round"
                style={{ transition:"stroke-dashoffset 0.5s,stroke 0.3s" }}
              />
            </svg>
            <div style={{
              position:"absolute",inset:0,display:"flex",flexDirection:"column",
              alignItems:"center",justifyContent:"center",
            }}>
              <div style={{
                fontSize:14,fontWeight:900,
                color: bombPct > 40 ? "#FF3B30" : bombPct > 20 ? "#FF9F0A" : "#FFD60A",
              }}>{bombPct}%</div>
              <div style={{ fontSize:8,color:"rgba(255,255,255,0.4)",fontWeight:700 }}>💣</div>
            </div>
          </div>

          {/* Deck */}
          <div onClick={() => { if (!isYourTurn || isTrapped) return; drawCard(false); }}
            style={{
              position:"relative",cursor: isYourTurn && !isTrapped ? "pointer" : "default",
              animation:"float 3s ease-in-out infinite",
            }}
          >
            {[...Array(Math.min(3, gs.deck.length))].map((_, i) => (
              <div key={i} style={{
                position:"absolute",top:-(i*3),left:i*2,
                width:70,height:98,borderRadius:12,
                background:"linear-gradient(135deg,#2C1654,#1A0A3C)",
                border:"2px solid rgba(255,255,255,0.08)",
              }}/>
            ))}
            <div style={{
              position:"relative",width:70,height:98,borderRadius:12,
              background:"linear-gradient(135deg,#3D1F73,#2C1654)",
              border:`2px solid ${isYourTurn && !isTrapped ? "#FFD60A" : "rgba(255,255,255,0.18)"}`,
              display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",
              boxShadow: isYourTurn && !isTrapped ? "0 0 22px rgba(255,214,10,0.35)" : "0 6px 20px rgba(0,0,0,0.4)",
            }}>
              <div style={{ fontSize:26 }}>🂠</div>
              <div style={{ fontSize:10,color:"rgba(255,255,255,0.6)",fontWeight:800 }}>
                {gs.deck.length} كرت
              </div>
            </div>
          </div>

          {isTrapped && (
            <div style={{
              background:"#FF3B30",borderRadius:12,padding:"4px 10px",
              color:"white",fontSize:12,fontWeight:800,
              animation:"pulse 1s infinite",textAlign:"center",
            }}>⚠️ اسحب ×{yourTrap}</div>
          )}
          {isYourTurn && !isTrapped && (
            <div style={{ color:"rgba(255,214,10,0.8)",fontSize:10,fontWeight:800 }}>
              اضغط للسحب
            </div>
          )}
        </div>

        {/* Direction Arrow + Turn Info */}
        <div style={{ display:"flex",flexDirection:"column",alignItems:"center",gap:8 }}>
          {/* Direction indicator */}
          <div style={{
            width:50,height:50,borderRadius:"50%",
            background:"rgba(255,255,255,0.07)",border:"1px solid rgba(255,255,255,0.15)",
            display:"flex",alignItems:"center",justifyContent:"center",
            animation: "spin 3s linear infinite",
            animationDirection: direction === 1 ? "normal" : "reverse",
          }}>
            <span style={{ fontSize:26 }}>🔃</span>
          </div>
          <div style={{
            fontSize:9,color:"rgba(255,255,255,0.4)",fontWeight:700,textAlign:"center",
          }}>{direction === 1 ? "←" : "→"} الاتجاه</div>
          {/* Turn indicator */}
          <div style={{
            background:"rgba(0,0,0,0.35)",borderRadius:16,padding:"6px 14px",
            display:"flex",alignItems:"center",gap:6,
          }}>
            <span style={{ fontSize:16 }}>{currentPl?.avatar}</span>
            <span style={{
              color: isYourTurn ? "#FFD60A" : "white",fontWeight:800,fontSize:12,
            }}>{isYourTurn ? "دورك!" : currentPl?.name?.split(" ")[0]}</span>
          </div>
        </div>

        {/* Last played card */}
        <div style={{ display:"flex",flexDirection:"column",alignItems:"center",gap:6 }}>
          {lastAction?.card ? (
            <div style={{ animation:"slideUp 0.3s ease" }}>
              <CardUI card={lastAction.card} size="lg" trapStack={lastAction.card.type==="trap" ? 2 : 0}/>
            </div>
          ) : (
            <div style={{
              width:110,height:154,borderRadius:12,
              border:"2px dashed rgba(255,255,255,0.12)",
              display:"flex",alignItems:"center",justifyContent:"center",
            }}>
              <span style={{ fontSize:28,opacity:0.15 }}>🃏</span>
            </div>
          )}
          <div style={{
            fontSize:10,color:"rgba(255,255,255,0.35)",textAlign:"center",maxWidth:120,
          }}>
            {lastAction?.card ? CARD_DEFS[lastAction.card.type]?.desc : "آخر كرت"}
          </div>
        </div>
      </div>

      {/* ── YOUR HAND ─────────────────────────────────────────────── */}
      <div style={{ flexShrink:0,padding:"6px 0 4px" }}>
        <div style={{
          overflowX:"auto",display:"flex",gap:8,padding:"8px 14px 10px",
          scrollbarWidth:"none",
        }}>
          {yourHand.map(card => (
            <div key={card.id}>
              <CardUI
                card={card}
                size="md"
                selected={selectedCard === card.id}
                disabled={!isYourTurn || !cardAllowed(card)}
                onClick={() => {
                  if (!isYourTurn || !cardAllowed(card)) return;
                  if (["trap","demand","exchange"].includes(card.type)) {
                    setSelectedCard(card.id);
                    setSelectingFor(card.type);
                  } else if (selectedCard === card.id) {
                    playCard(card.id);
                  } else {
                    setSelectedCard(card.id);
                    setSelectingFor(null);
                  }
                }}
              />
            </div>
          ))}
          {yourHand.length === 0 && (
            <div style={{ color:"rgba(255,255,255,0.3)",fontSize:13,padding:"28px 20px" }}>
              لا توجد كروت
            </div>
          )}
        </div>

        {/* Action buttons */}
        <div style={{
          display:"flex",gap:8,padding:"0 14px 10px",
          overflowX:"auto",scrollbarWidth:"none",alignItems:"center",
        }}>
          {selectedCard && !selectingFor && (
            <button onClick={() => playCard(selectedCard)} style={{
              padding:"10px 20px",borderRadius:50,
              background:"linear-gradient(135deg,#30D158,#27AE60)",
              border:"none",color:"white",fontWeight:800,fontSize:14,cursor:"pointer",
              flexShrink:0,fontFamily:"'Baloo 2',cursive",
              boxShadow:"0 4px 12px rgba(48,209,88,0.4)",
            }}>▶ العب</button>
          )}
          {selectingFor && (
            <div style={{
              color:"#FFD60A",fontWeight:800,fontSize:12,padding:"8px",flexShrink:0,
              background:"rgba(255,214,10,0.12)",borderRadius:12,
            }}>
              اختر الهدف ↑
            </div>
          )}
          {selectedCard && (
            <button onClick={() => { setSelectedCard(null); setSelectingFor(null); }} style={{
              padding:"10px 16px",borderRadius:50,
              background:"rgba(255,255,255,0.1)",border:"1px solid rgba(255,255,255,0.2)",
              color:"white",fontWeight:700,fontSize:12,cursor:"pointer",flexShrink:0,
              fontFamily:"'Baloo 2',cursive",
            }}>إلغاء</button>
          )}
          {isYourTurn && isTrapped && !selectingFor && (
            <button onClick={() => drawCard(false)} style={{
              padding:"10px 20px",borderRadius:50,
              background:"linear-gradient(135deg,#FF3B30,#C0392B)",
              border:"none",color:"white",fontWeight:800,fontSize:13,cursor:"pointer",
              flexShrink:0,fontFamily:"'Baloo 2',cursive",animation:"pulse 1s infinite",
            }}>💥 اسحب ×{yourTrap}</button>
          )}
        </div>

        {/* Target selection row */}
        {selectingFor && (
          <div style={{
            display:"flex",gap:8,padding:"0 14px 10px",
            overflowX:"auto",scrollbarWidth:"none",
          }}>
            {alivePs(gs).filter(p => p.id !== "you").map(p => (
              <button key={p.id} onClick={() => playCard(selectedCard, p.id)} style={{
                padding:"8px 14px",borderRadius:50,flexShrink:0,
                background:"linear-gradient(135deg,#FF9F0A,#E67E22)",
                border:"none",color:"white",fontWeight:800,fontSize:12,cursor:"pointer",
                fontFamily:"'Baloo 2',cursive",
                display:"flex",alignItems:"center",gap:6,
              }}>
                <span>{p.avatar}</span>{p.name.split(" ")[0]}
              </button>
            ))}
            {/* Allow targeting self with Trap */}
            {selectingFor === "trap" && (
              <button onClick={() => playCard(selectedCard, "you")} style={{
                padding:"8px 14px",borderRadius:50,flexShrink:0,
                background:"rgba(255,255,255,0.1)",border:"1px solid rgba(255,255,255,0.2)",
                color:"white",fontWeight:800,fontSize:12,cursor:"pointer",
                fontFamily:"'Baloo 2',cursive",display:"flex",alignItems:"center",gap:6,
              }}>
                <span>😎</span>أنا
              </button>
            )}
          </div>
        )}
      </div>

      {/* ── BOMB MODAL ────────────────────────────────────────────── */}
      {modal?.type === "bomb" && (
        <div style={{
          position:"fixed",inset:0,zIndex:1000,
          background:"rgba(255,59,48,0.28)",backdropFilter:"blur(10px)",
          display:"flex",alignItems:"center",justifyContent:"center",padding:20,
        }}>
          <div style={{
            background:"linear-gradient(160deg,#2C1654,#1A0A3C)",
            border:"2px solid #FF3B30",borderRadius:24,padding:28,
            maxWidth:320,width:"100%",textAlign:"center",
            boxShadow:"0 0 80px rgba(255,59,48,0.6)",
            animation:"shake 0.5s ease,pulse 1s 0.5s infinite",
          }}>
            <div style={{ fontSize:64,lineHeight:1,marginBottom:8 }}>💣</div>
            <h2 style={{ color:"#FF3B30",fontSize:26,fontWeight:900,margin:"0 0 6px" }}>BOMB!</h2>
            <p style={{ color:"rgba(255,255,255,0.7)",fontSize:14,marginBottom:18 }}>سحبت قنبلة!</p>
            {modal.hasDisable ? (
              <>
                <p style={{ color:"#30D158",fontWeight:800,marginBottom:14 }}>
                  🔑 عندك Disable — استخدمها؟
                </p>
                <BombPlacement deckSize={gs.deck.length} onConfirm={pos => handleBombResponse(true, pos)}/>
                <button onClick={() => handleBombResponse(false)} style={{
                  width:"100%",padding:"12px 0",marginTop:10,borderRadius:50,
                  background:"rgba(255,255,255,0.09)",border:"1px solid rgba(255,255,255,0.2)",
                  color:"rgba(255,255,255,0.55)",fontWeight:700,fontSize:13,cursor:"pointer",
                  fontFamily:"'Baloo 2',cursive",
                }}>لا، استسلم 😢</button>
              </>
            ) : (
              <>
                <p style={{ color:"#FF3B30",fontWeight:800,marginBottom:18 }}>
                  ليس معك Disable... أنت خارج! 💀
                </p>
                <button onClick={() => handleBombResponse(false)} style={{
                  width:"100%",padding:"14px 0",borderRadius:50,
                  background:"linear-gradient(135deg,#FF3B30,#C0392B)",
                  border:"none",color:"white",fontWeight:900,fontSize:15,cursor:"pointer",
                  fontFamily:"'Baloo 2',cursive",
                }}>خرجت من اللعبة 💥</button>
              </>
            )}
          </div>
        </div>
      )}

      {/* ── XRAY MODAL ────────────────────────────────────────────── */}
      {modal?.type === "xray" && (
        <Modal onClose={() => setModal(null)}>
          <div style={{ textAlign:"center" }}>
            <div style={{ fontSize:32,marginBottom:8 }}>🔮</div>
            <h3 style={{ color:"white",fontWeight:900,marginBottom:4 }}>X-Ray</h3>
            <p style={{ color:"rgba(255,255,255,0.5)",fontSize:12,marginBottom:18 }}>
              أعلى 3 كروت في المجموعة (أنت فقط تراها) · ثم العب مجدداً
            </p>
            <div style={{ display:"flex",justifyContent:"center",gap:10,marginBottom:20 }}>
              {modal.cards.length ? modal.cards.map((c, i) => (
                <div key={i} style={{ animation:`slideUp 0.3s ease ${i*0.1}s both` }}>
                  <CardUI card={c} size="md"/>
                </div>
              )) : (
                <p style={{ color:"rgba(255,255,255,0.4)" }}>المجموعة فارغة!</p>
              )}
            </div>
            <button onClick={() => setModal(null)} style={{
              width:"100%",padding:"12px 0",borderRadius:50,
              background:"linear-gradient(135deg,#BF5AF2,#8E44AD)",
              border:"none",color:"white",fontWeight:800,cursor:"pointer",
              fontFamily:"'Baloo 2',cursive",
            }}>حسناً، سألعب مجدداً!</button>
          </div>
        </Modal>
      )}

      {/* ── PROPHECY MODAL ────────────────────────────────────────── */}
      {modal?.type === "prophecy" && (
        <Modal onClose={() => setModal(null)}>
          <div style={{ textAlign:"center" }}>
            <div style={{ fontSize:32,marginBottom:8 }}>💡</div>
            <h3 style={{ color:"white",fontWeight:900,marginBottom:14 }}>Prophecy</h3>
            {modal.pos === -1 || modal.pos === undefined ? (
              <p style={{ color:"#30D158",fontWeight:800,fontSize:16 }}>
                🎉 لا توجد قنابل في المجموعة!
              </p>
            ) : (
              <div style={{
                background:"rgba(255,214,10,0.1)",border:"1px solid rgba(255,214,10,0.3)",
                borderRadius:16,padding:16,marginBottom:14,
              }}>
                <p style={{ color:"rgba(255,255,255,0.6)",fontSize:13,margin:0 }}>أقرب قنبلة في الموضع</p>
                <p style={{ color:"#FFD60A",fontWeight:900,fontSize:38,margin:"4px 0" }}>
                  #{modal.pos + 1}
                </p>
                <p style={{ color:"rgba(255,255,255,0.4)",fontSize:12,margin:0 }}>
                  من أعلى المجموعة ({gs.deck.length} كرت إجمالي)
                </p>
              </div>
            )}
            <button onClick={() => setModal(null)} style={{
              width:"100%",padding:"12px 0",borderRadius:50,
              background:"linear-gradient(135deg,#FFD60A,#F39C12)",
              border:"none",color:"#1A0A3C",fontWeight:900,cursor:"pointer",
              fontFamily:"'Baloo 2',cursive",marginTop:8,
            }}>حسناً، سألعب مجدداً!</button>
          </div>
        </Modal>
      )}
    </div>
  );
}

/* ══════════════════════════════ RESULTS SCREEN ══════════════════════════════ */
function ResultsScreen({ result, onPlayAgain, onHome }) {
  const { players, goldMap, winnerId, stake } = result;
  const sorted = [...players].sort((a, b) => (a.rank||99) - (b.rank||99));
  const winner = players.find(p => p.id === winnerId);

  return (
    <div style={{
      minHeight:"100vh",fontFamily:"'Baloo 2',cursive",
      background:"linear-gradient(160deg,#5B2D8E 0%,#3A1A6E 50%,#1A0A3C 100%)",
      display:"flex",flexDirection:"column",alignItems:"center",
      padding:"30px 20px",position:"relative",overflow:"hidden",
    }}>
      {[...Array(20)].map((_,i) => (
        <div key={i} style={{
          position:"absolute",left:`${Math.random()*100}%`,top:-20,fontSize:20,
          animation:`confetti ${2+Math.random()*3}s ease ${Math.random()*2}s both`,opacity:0,
        }}>{["🎉","⭐","💥","🎊","✨"][i%5]}</div>
      ))}

      <div style={{ zIndex:10,textAlign:"center",marginBottom:24 }}>
        <div style={{ fontSize:64 }}>🏆</div>
        <h1 style={{
          color:"#FFD60A",fontSize:26,fontWeight:900,margin:"8px 0 4px",
          textShadow:"0 0 30px rgba(255,214,10,0.6)",
        }}>
          {winner?.id === "you" ? "أنت الفائز! 🎉" : `${winner?.name} فاز!`}
        </h1>
        <p style={{ color:"rgba(255,255,255,0.5)",fontSize:13,margin:0 }}>الرهان: {stake} Gold</p>
      </div>

      <div style={{
        width:"100%",maxWidth:340,zIndex:10,
        background:"rgba(255,255,255,0.06)",borderRadius:20,
        border:"1px solid rgba(255,255,255,0.1)",overflow:"hidden",marginBottom:24,
      }}>
        <div style={{
          display:"grid",gridTemplateColumns:"40px 1fr 80px",
          background:"rgba(0,0,0,0.2)",padding:"10px 16px",
          color:"rgba(255,255,255,0.4)",fontSize:11,fontWeight:800,
        }}>
          <span>مركز</span><span>لاعب</span><span style={{ textAlign:"right" }}>Gold</span>
        </div>
        {sorted.map((p, i) => {
          const gold   = goldMap[p.id] || 0;
          const medals = ["🥇","🥈","🥉","4️⃣","5️⃣"];
          return (
            <div key={p.id} style={{
              display:"grid",gridTemplateColumns:"40px 1fr 80px",
              padding:"12px 16px",alignItems:"center",
              background: p.id === "you" ? "rgba(255,214,10,0.08)" : "transparent",
              borderTop:"1px solid rgba(255,255,255,0.06)",
              animation:`slideUp 0.4s ease ${i*0.1}s both`,
            }}>
              <span style={{ fontSize:20 }}>{medals[i]||"👤"}</span>
              <div style={{ display:"flex",alignItems:"center",gap:8 }}>
                <span style={{ fontSize:22 }}>{p.avatar}</span>
                <div>
                  <div style={{ color:"white",fontWeight:800,fontSize:14 }}>{p.name}</div>
                  {p.id === "you" && <div style={{ color:"#FFD60A",fontSize:10,fontWeight:700 }}>أنت</div>}
                </div>
              </div>
              <div style={{
                textAlign:"right",fontWeight:900,fontSize:16,
                color: gold>0 ? "#30D158" : gold<0 ? "#FF3B30" : "rgba(255,255,255,0.4)",
              }}>{gold>0?"+":""}{gold}</div>
            </div>
          );
        })}
      </div>

      <div style={{ zIndex:10,width:"100%",maxWidth:340,display:"flex",flexDirection:"column",gap:10 }}>
        <button onClick={onPlayAgain} style={{
          width:"100%",padding:"16px 0",borderRadius:50,
          background:"linear-gradient(135deg,#30D158,#27AE60)",
          border:"none",color:"white",fontSize:18,fontWeight:900,cursor:"pointer",
          fontFamily:"'Baloo 2',cursive",boxShadow:"0 8px 24px rgba(48,209,88,0.4)",
        }}>🎮 العب مجدداً</button>
        <button onClick={onHome} style={{
          width:"100%",padding:"13px 0",borderRadius:50,
          background:"rgba(255,255,255,0.08)",border:"1px solid rgba(255,255,255,0.15)",
          color:"rgba(255,255,255,0.7)",fontSize:15,fontWeight:700,cursor:"pointer",
          fontFamily:"'Baloo 2',cursive",
        }}>🏠 الرئيسية</button>
      </div>
    </div>
  );
}

/* ════════════════════════════════ MAIN APP ══════════════════════════════════ */
export default function DefuseMasterApp() {
  const [screen, setScreen] = useState("lobby");
  const [config, setConfig] = useState(null);
  const [result, setResult] = useState(null);

  return (
    <div style={{ maxWidth:430,margin:"0 auto",position:"relative" }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;600;700;800;900&display=swap');
        @keyframes circleIn { from{opacity:0;transform:scale(0.5)} to{opacity:1;transform:scale(1)} }
        @keyframes fadeIn   { from{opacity:0;transform:scale(0.8) translateY(10px)} to{opacity:1;transform:scale(1) translateY(0)} }
        @keyframes modalIn  { from{opacity:0;transform:scale(0.9)} to{opacity:1;transform:scale(1)} }
        @keyframes shake    { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-10px)} 40%{transform:translateX(10px)} 60%{transform:translateX(-6px)} 80%{transform:translateX(6px)} }
        @keyframes pulse    { 0%,100%{box-shadow:0 0 20px rgba(255,59,48,0.4)} 50%{box-shadow:0 0 60px rgba(255,59,48,0.9)} }
        @keyframes float    { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }
        @keyframes glow     { 0%,100%{box-shadow:0 0 10px rgba(255,214,10,0.3)} 50%{box-shadow:0 0 30px rgba(255,214,10,0.8)} }
        @keyframes slideUp  { from{transform:translateY(30px);opacity:0} to{transform:translateY(0);opacity:1} }
        @keyframes spin     { to{transform:rotate(360deg)} }
        @keyframes confetti { 0%{transform:translateY(-10px) rotate(0deg);opacity:1} 100%{transform:translateY(100vh) rotate(720deg);opacity:0} }
        * { -webkit-tap-highlight-color: transparent; box-sizing: border-box; }
        input[type=range] { height:6px; border-radius:3px; }
        ::-webkit-scrollbar { display:none; }
      `}</style>

      {screen === "lobby" && (
        <LobbyScreen onStart={cfg => { setConfig(cfg); setScreen("game"); }}/>
      )}
      {screen === "game" && config && (
        <GameScreen
          config={config}
          onEnd={res => { setResult(res); setScreen("results"); }}
        />
      )}
      {screen === "results" && result && (
        <ResultsScreen
          result={result}
          onPlayAgain={() => { setResult(null); setScreen("game"); }}
          onHome={() => { setResult(null); setConfig(null); setScreen("lobby"); }}
        />
      )}
    </div>
  );
}

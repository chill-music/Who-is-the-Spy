          <div style={{ display:"flex",gap:8 }}>
            {[50,100,500,1000].map(s => (
              <button key={s} onClick={() => setStake(s)} style={{
                flex:1,padding:"8px 0",borderRadius:12,
                background: stake===s ? "linear-gradient(135deg,#FFD60A,#FF9F0A)" : "rgba(255,255,255,0.08)",
                border:"none",color: stake===s ? "#1A0A3C" : "white",
